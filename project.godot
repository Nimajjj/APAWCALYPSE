; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="APAWCALYPSE"
run/main_scene="res://scenes/ui/splash_screen.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://assets/debug/icon.svg"

[audio]

buses/default_bus_layout="res://resources/default_bus_layout.tres"

[autoload]

Global="*res://scripts/autoload/global.gd"
EventBus="*res://scripts/autoload/event_bus.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
InputSetup="*res://scripts/autoload/input_setup.gd"
SoundManager="*res://scripts/autoload/sound_manager.gd"
AchievementManager="*res://scripts/autoload/achievement_manager.gd"
Notifier="*res://scripts/ui/notifier.gd"
Juice="*res://scripts/autoload/juice.gd"
Transitions="*res://scripts/autoload/transitions.gd"
BulletPool="*res://scripts/autoload/bullet_pool.gd"
UITheme="*res://scripts/autoload/ui_theme.gd"
Balance="*res://scripts/autoload/balance.gd"
GameConfig="*res://scripts/autoload/game_config.gd"
Progression="*res://scripts/autoload/progression.gd"
DevWebPanel="*res://scripts/autoload/dev_web_panel.gd"
CRTOverlay="*res://scripts/autoload/crt_overlay.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"

[editor]

version_control/plugin_name="GitPlugin"

[gui]

theme/custom="res://resources/ui_theme.tres"

